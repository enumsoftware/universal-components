{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false,
    "isolatedModules": true,
    "useDefineForClassFields": false
  },
  "exclude": ["node_modules", "storybook-static", "**/*.spec.ts"]
}
