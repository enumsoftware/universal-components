{
  "name": "@enumsoftware/universal-components",
  "version": "0.1.1",
  "description": "Reusable Angular standalone UI components for Enum Software apps",
  "scripts": {
    "build": "ng build universal-components",
    "prepare": "npm run build",
    "pack:dist": "npm run build ; npm pack",
    "storybook": "ng run storybook:storybook",
    "storybook:a11y": "test-storybook --url http://127.0.0.1:6006 --maxWorkers=2",
    "storybook:build": "ng run storybook:build-storybook",
    "test": "ng test universal-components",
    "tokens:check": "node scripts/check-token-parity.cjs"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enumsoftware/universal-components.git"
  },
  "bugs": {
    "url": "https://github.com/enumsoftware/universal-components/issues"
  },
  "homepage": "https://github.com/enumsoftware/universal-components#readme",
  "sideEffects": false,
  "files": [
    "dist/**",
    "themes/**/*.css",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/enumsoftware-universal-components.d.ts",
      "default": "./dist/fesm2022/enumsoftware-universal-components.mjs"
    },
    "./public-api": {
      "types": "./dist/types/enumsoftware-universal-components.d.ts",
      "default": "./dist/fesm2022/enumsoftware-universal-components.mjs"
    },
    "./themes/uc-light.css": "./themes/uc-light.css",
    "./themes/uc-dark.css": "./themes/uc-dark.css",
    "./package.json": "./package.json"
  },
  "module": "dist/fesm2022/enumsoftware-universal-components.mjs",
  "typings": "dist/types/enumsoftware-universal-components.d.ts",
  "type": "module",
  "peerDependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/aria": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "^7.8.0"
  },
  "dependencies": {
    "@phosphor-icons/web": "^2.1.2",
    "d3": "^7.9.0",
    "flag-icons": "^7.5.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/storybook-angular": "^2.6.2",
    "@analogjs/vite-plugin-angular": "^2.6.2",
    "@angular-devkit/architect": "^0.2200.0",
    "@angular-devkit/build-angular": "^22.0.0",
    "@angular/animations": "^22.0.0",
    "@angular/aria": "^22.0.0",
    "@angular/build": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@storybook/addon-a11y": "^10.5.3",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/angular": "^10.5.3",
    "@storybook/test-runner": "^0.24.4",
    "@types/d3": "^7.4.3",
    "@types/jasmine": "^5.1.12",
    "jasmine-core": "^5.12.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "ng-packagr": "^22.0.0",
    "rxjs": "^7.8.0",
    "storybook": "^10.5.3",
    "typescript": "~6.0.0",
    "vite": "^8.1.0",
    "vitest": "^3.2.4",
    "zone.js": "^0.15.1"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "esbuild@0.28.1": true,
    "@parcel/watcher@2.5.6": true,
    "lmdb@3.5.4": true,
    "msgpackr-extract@3.0.4": true
  }
}
